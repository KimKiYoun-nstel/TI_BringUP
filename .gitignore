# OS / editor
.DS_Store
Thumbs.db
.vscode/
.idea/
*:Zone.Identifier

# logs that are too large; curated logs should be committed as markdown
*.log
*.tmp
!/logs/**/*.log
/logs/runtime_log

# Local BSP source workspaces copied from TI SDK
/workspace/

# Local build/deploy outputs
/out/
/deploy/
/build-output/
/tmp-build/
/build/
/tmp/

# archives
*.zip
*.tar
*.tar.gz
*.tar.xz

# Local env files. Commit the matching .env.example only.
/tools/env/*.env
!/tools/env/*.env.example

# Heavy generated artifacts
*.wic
*.wic.xz
*.img
*.cpio
*.cpio.gz
*.itb
*.dtb
*.dtbo
*.bin
*.map
*.elf
*.o
*.ko
*.mod
*.mod.c
*.cmd
*.order
*.symvers

# Mounted SD card paths or local scratch
/mnt-sd/
/sdcard/
/scratch/

# Local TFTP root payloads are operator-managed artifacts, not git-tracked outputs.
/tftp/*
!/tftp/README.md

.sisyphus/run-continuation
logs/uartd.*
logs/runtime_log.pre*
tools/uart/__pycache__
tests/tools/uart/__pycache__

.sisyphus/
.opencode/
!.opencode/
/.opencode/*
!.opencode/skills/
/.opencode/skills/*
!.opencode/skills/**/
!.opencode/skills/**/SKILL.md
/.agents/
/firmware/
/token-usage-output.txt
