#!/usr/bin/env bash
# TI AM64x Processor SDK Linux 12.00.00.07.04 environment template.
# Copy this file to sdk-12.00.00.07.04.env and adjust paths if needed.

export TI_WORKSPACE="$HOME/ti"
export BRINGUP_ROOT="$TI_WORKSPACE/TI_Bringup"

export SDK_VERSION="12.00.00.07.04"
export SDK_ROOT="$TI_WORKSPACE/am64x/ti-processor-sdk-linux-am64xx-evm-12.00.00.07.04"

export BOARD_SUPPORT="$SDK_ROOT/board-support"
export PREBUILT_IMAGES="$BOARD_SUPPORT/prebuilt-images"
export FILESYSTEM="$SDK_ROOT/filesystem"

export LINUX_DEVKIT="$SDK_ROOT/linux-devkit"
export K3R5_DEVKIT="$SDK_ROOT/k3r5-devkit"

export UBOOT_SDK_SRC="$BOARD_SUPPORT/ti-u-boot-2026.01+git"
export KERNEL_SDK_SRC="$BOARD_SUPPORT/ti-linux-kernel-6.18.13+git-ti"
export TFA_SDK_SRC="$BOARD_SUPPORT/trusted-firmware-a-2.14+git"
export OPTEE_SDK_SRC="$BOARD_SUPPORT/optee-os-4.9.0+git"

export WORKSPACE_ROOT="$BRINGUP_ROOT/workspace"
export UBOOT_SRC="$WORKSPACE_ROOT/ti-u-boot-sdk12"
export KERNEL_SRC="$WORKSPACE_ROOT/ti-linux-kernel-sdk12"

# AArch64 Linux cross compiler used by kernel/U-Boot A53 builds.
export ARCH="arm64"
export CROSS_COMPILE_AARCH64="$LINUX_DEVKIT/sysroots/x86_64-arago-linux/usr/bin/aarch64-oe-linux/aarch64-oe-linux-"

# R5 toolchain path may be required by U-Boot R5/SPL build flow.
export CROSS_COMPILE_ARMV7R="$K3R5_DEVKIT/sysroots/x86_64-arago-linux/usr/bin/arm-oe-eabi/arm-oe-eabi-"
