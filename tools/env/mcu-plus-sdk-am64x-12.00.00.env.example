#!/usr/bin/env bash
# TI AM64x MCU+ SDK 12.00.00 workspace environment template.
# Copy this file to mcu-plus-sdk-am64x-12.00.00.env and adjust paths if needed.

export TI_WORKSPACE="$HOME/ti"
export BRINGUP_ROOT="$TI_WORKSPACE/TI_Bringup"

export MCU_PLUS_SDK_VERSION="12.00.00"
export MCU_PLUS_SDK_INSTALL_ROOT="$TI_WORKSPACE/am64x/mcu_plus_sdk_am64x_12_00_00_27"
export MCU_PLUS_SDK_PATH="$BRINGUP_ROOT/workspace/mcu_plus_sdk_am64x_12_00_00_27"
export MCU_PLUS_CCS_PROJECTS_DIR="$MCU_PLUS_SDK_PATH/ccs_projects"

export TOOLS_PATH="$TI_WORKSPACE"
export CCS_PATH="$TOOLS_PATH/ccs2040/ccs"
export SYSCFG_PATH="$CCS_PATH/utils/sysconfig_1.26.0"
export CGT_TI_ARM_CLANG_PATH="$CCS_PATH/tools/compiler/ti-cgt-armllvm_4.0.4.LTS"
export CGT_GCC_AARCH64_PATH="$TOOLS_PATH/gcc-arm-9.2-2019.12-x86_64-aarch64-none-elf"

# Optional; needed only for gcc-arm based R5/M4 examples.
export CGT_GCC_ARM_PATH="$TOOLS_PATH/gcc-arm-none-eabi-9-2019-q4-major"
export CGT_GCC_ARMV7_PATH="$CGT_GCC_ARM_PATH"

export PATH="$CGT_GCC_AARCH64_PATH/bin:$CGT_TI_ARM_CLANG_PATH/bin:$PATH"
