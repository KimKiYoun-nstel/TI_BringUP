/* Root-managed final integration overrides for CPU_BRD_V03_PBA_260511. */
/* Derived from workflow final and selected as bringup-default build set. */

/ {
	led-controller {
		compatible = "gpio-leds";

		test-led2 {
			gpios = <&mcu_gpio0 5 GPIO_ACTIVE_HIGH>;
			default-state = "off";
		};

		test-led1 {
			gpios = <&main_gpio0 60 GPIO_ACTIVE_HIGH>;
			default-state = "off";
		};
	};
};

&main_pmx0 {
	main_usb0_pins_default: main-usb0-default-pins {
		pinctrl-single,pins = <
			AM64X_IOPAD(0x02a8, PIN_OUTPUT, 0) /* (E19) USB0_DRVVBUS */
		>;
	};

	main_uart2_rx_pins_fixup: main-uart2-rx-pins-fixup {
		pinctrl-single,pins = <
			AM64X_IOPAD(0x0184, PIN_INPUT, 10) /* (W6) PRG0_PRU0_GPO9.UART2_RXD */
		>;
	};

	mdio1_pins_default: mdio1-default-pins {
		pinctrl-single,pins = <
			AM64X_IOPAD(0x01fc, PIN_OUTPUT, 4) /* (R2) PRG0_PRU1_GPO19.MDIO0_MDC */
			AM64X_IOPAD(0x01f8, PIN_INPUT, 4) /* (P5) PRG0_PRU1_GPO18.MDIO0_MDIO */
		>;
	};

	rgmii1_pins_default: rgmii1-default-pins {
		pinctrl-single,pins = <
			AM64X_IOPAD(0x011c, PIN_INPUT, 4) /* (AA13) PRG1_PRU1_GPO5.RGMII1_RD0 */
			AM64X_IOPAD(0x0128, PIN_INPUT, 4) /* (U12) PRG1_PRU1_GPO8.RGMII1_RD1 */
			AM64X_IOPAD(0x0150, PIN_INPUT, 4) /* (Y13) PRG1_PRU1_GPO18.RGMII1_RD2 */
			AM64X_IOPAD(0x0154, PIN_INPUT, 4) /* (V12) PRG1_PRU1_GPO19.RGMII1_RD3 */
			AM64X_IOPAD(0x00d8, PIN_INPUT, 4) /* (W13) PRG1_PRU0_GPO8.RGMII1_RXC */
			AM64X_IOPAD(0x00cc, PIN_INPUT, 4) /* (V13) PRG1_PRU0_GPO5.RGMII1_RX_CTL */
			AM64X_IOPAD(0x0124, PIN_OUTPUT, 4) /* (V15) PRG1_PRU1_GPO7.RGMII1_TD0 */
			AM64X_IOPAD(0x012c, PIN_OUTPUT, 4) /* (V14) PRG1_PRU1_GPO9.RGMII1_TD1 */
			AM64X_IOPAD(0x0130, PIN_OUTPUT, 4) /* (W14) PRG1_PRU1_GPO10.RGMII1_TD2 */
			AM64X_IOPAD(0x014c, PIN_OUTPUT, 4) /* (AA14) PRG1_PRU1_GPO17.RGMII1_TD3 */
			AM64X_IOPAD(0x00e0, PIN_OUTPUT, 4) /* (U14) PRG1_PRU0_GPO10.RGMII1_TXC */
			AM64X_IOPAD(0x00dc, PIN_OUTPUT, 4) /* (U15) PRG1_PRU0_GPO9.RGMII1_TX_CTL */
		>;
	};

	rgmii2_pins_default: rgmii2-default-pins {
		pinctrl-single,pins = <
			AM64X_IOPAD(0x0108, PIN_INPUT, 4) /* (W11) PRG1_PRU1_GPO0.RGMII2_RD0 */
			AM64X_IOPAD(0x010c, PIN_INPUT, 4) /* (V11) PRG1_PRU1_GPO1.RGMII2_RD1 */
			AM64X_IOPAD(0x0110, PIN_INPUT, 4) /* (AA12) PRG1_PRU1_GPO2.RGMII2_RD2 */
			AM64X_IOPAD(0x0114, PIN_INPUT, 4) /* (Y12) PRG1_PRU1_GPO3.RGMII2_RD3 */
			AM64X_IOPAD(0x0120, PIN_INPUT, 4) /* (U11) PRG1_PRU1_GPO6.RGMII2_RXC */
			AM64X_IOPAD(0x0118, PIN_INPUT, 4) /* (W12) PRG1_PRU1_GPO4.RGMII2_RX_CTL */
			AM64X_IOPAD(0x0134, PIN_OUTPUT, 4) /* (AA10) PRG1_PRU1_GPO11.RGMII2_TD0 */
			AM64X_IOPAD(0x0138, PIN_OUTPUT, 4) /* (V10) PRG1_PRU1_GPO12.RGMII2_TD1 */
			AM64X_IOPAD(0x013c, PIN_OUTPUT, 4) /* (U10) PRG1_PRU1_GPO13.RGMII2_TD2 */
			AM64X_IOPAD(0x0140, PIN_OUTPUT, 4) /* (AA11) PRG1_PRU1_GPO14.RGMII2_TD3 */
			AM64X_IOPAD(0x0148, PIN_OUTPUT, 4) /* (Y10) PRG1_PRU1_GPO16.RGMII2_TXC */
			AM64X_IOPAD(0x0144, PIN_OUTPUT, 4) /* (Y11) PRG1_PRU1_GPO15.RGMII2_TX_CTL */
		>;
	};
};

&main_gpio0 {
	status = "okay";
};

&mcu_gpio0 {
	status = "okay";
};

&mcu_uart0 {
	status = "okay";
	pinctrl-names = "default";
	pinctrl-0 = <&mcu_uart0_pins_default>;
};

&main_uart0 {
	status = "okay";
	pinctrl-names = "default";
	pinctrl-0 = <&main_uart0_pins_default>;
};

&main_uart2 {
	status = "okay";
	pinctrl-names = "default";
	pinctrl-0 = <&main_uart2_pins_default &main_uart2_rx_pins_fixup>;
	/* UART2 final candidate uses K19/UART2_TXD from MMC page and W6/UART2_RXD from PRG/debug netlist evidence. */
};

&main_i2c0 {
	status = "okay";
	pinctrl-names = "default";
	pinctrl-0 = <&main_i2c0_pins_default>;
	clock-frequency = <400000>;

	u14: u14@51 {
		compatible = "atmel,24c512";
		reg = <0x51>;
	};

	/* TODO: add pmic@30 after TPS6522053 Linux binding and regulator constraints are confirmed. */
};

&main_i2c1 {
	status = "okay";
	pinctrl-names = "default";
	pinctrl-0 = <&main_i2c1_pins_default>;
	clock-frequency = <400000>;

	u20: u20@48 {
		compatible = "ti,ads1115";
		reg = <0x48>;
	};

	/* TODO: U15 TPM is intentionally omitted until compatible string and production enable policy are confirmed. */
	/* TODO: U21 PI6ULS5V9509UEX address/role is still unresolved. */
};

&sdhci0 {
	status = "okay";
	bus-width = <8>;
	non-removable;
	/* TODO: add reset, vmmc/vqmmc, and driver-strength properties after power tree review. */
};

&sdhci1 {
	status = "disabled";
	/* Board decision: MMC1 SD 4-bit path is not used. */
};

&ospi0 {
	status = "okay";
	pinctrl-names = "default";
	pinctrl-0 = <&ospi0_pins_default>;

	flash@0 {
		compatible = "jedec,spi-nor";
		reg = <0x0>;
		spi-tx-bus-width = <1>;
		spi-rx-bus-width = <1>;
		spi-max-frequency = <25000000>;
		/* Initial safe profile: keep single SPI fallback until octal/DQS bring-up root cause is resolved. */
		/* TODO: confirm Macronix-specific timing, partitions, reset-gpios, interrupt-gpios, and later octal profile. */
	};
};

&cpsw3g {
	status = "okay";
	pinctrl-names = "default";
	pinctrl-0 = <&rgmii1_pins_default>, <&rgmii2_pins_default>;
};

&cpsw_port1 {
	status = "okay";
	phy-mode = "rgmii-rxid";
	phy-handle = <&cpsw3g_phy0>;
};

&cpsw_port2 {
	status = "okay";
	phy-mode = "rgmii-rxid";
	phy-handle = <&cpsw3g_phy1>;
};

&cpsw3g_mdio {
	status = "okay";
	pinctrl-names = "default";
	pinctrl-0 = <&mdio1_pins_default>;

	cpsw3g_phy0: ethernet-phy@0 {
		reg = <0>;
		ti,rx-internal-delay = <DP83867_RGMIIDCTL_2_00_NS>;
		ti,fifo-depth = <DP83867_PHYCR_FIFO_DEPTH_4_B_NIB>;
		/* TODO: map GPIO_CPSW1_RST and CPSW_RGMII1_INTn once GPIO provider path is finalized. */
	};

	cpsw3g_phy1: ethernet-phy@1 {
		reg = <1>;
		ti,rx-internal-delay = <DP83867_RGMIIDCTL_2_00_NS>;
		ti,fifo-depth = <DP83867_PHYCR_FIFO_DEPTH_4_B_NIB>;
		/* TODO: map GPIO_CPSW2_RST and CPSW_RGMII2_INTn once GPIO provider path is finalized. */
	};
};

&usbss0 {
	status = "disabled";
};

&usb0 {
	status = "disabled";
};

&serdes_ln_ctrl {
	status = "disabled";
};

&serdes_wiz0 {
	status = "disabled";
};

&serdes0 {
	status = "disabled";
};

&icssg0 {
	status = "disabled";
};

&icssg1 {
	status = "disabled";
};

&crypto {
	status = "disabled";
};

&main_r5fss0 {
	status = "disabled";
};

&main_r5fss0_core0 {
	status = "disabled";
};

&main_r5fss0_core1 {
	status = "disabled";
};

&main_r5fss1 {
	status = "disabled";
};

&main_r5fss1_core0 {
	status = "disabled";
};

&main_r5fss1_core1 {
	status = "disabled";
};

&mcu_m4fss {
	status = "disabled";
};

/* TODO: SERDES0 remains unresolved between PCIe/USB3/FPGA/VITA routing policies. */
