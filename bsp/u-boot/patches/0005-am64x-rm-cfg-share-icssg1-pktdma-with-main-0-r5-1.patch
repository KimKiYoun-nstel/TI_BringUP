From 0000000000000000000000000000000000000000 Mon Sep 17 00:00:00 2001
From: TI_Bringup Workspace Base <noreply@example.com>
Date: Thu, 2 Jul 2026 14:00:00 +0900
Subject: [PATCH] board: ti: am64x: share icssg1 pktdma with MAIN_0_R5_1

Path B `gptp_icssg_switch` remoteproc firmware opens ICSSG1 PKTDMA resources
through the non-secure host context `MAIN_0_R5_1 (36)`. Keep the baseline
Linux `A53_2 (12)` allocation intact and duplicate the same ICSSG1 PKTDMA
ranges to host 36 so the TMDS64EVM TSN test path and the baseline Linux path
can coexist.
---
 board/ti/am64x/rm-cfg.yaml | 30 ++++++++++++++++++++++++++++++
 1 file changed, 30 insertions(+)

diff --git a/board/ti/am64x/rm-cfg.yaml b/board/ti/am64x/rm-cfg.yaml
index 1cc4cd34430..c2d112a87ae 100644
--- a/board/ti/am64x/rm-cfg.yaml
+++ b/board/ti/am64x/rm-cfg.yaml
@@ -841,6 +841,12 @@ rm-cfg:
             type: 1941
             host_id: 12
             reserved: 0
+        -
+            start_resource: 104
+            num_resource: 8
+            type: 1941
+            host_id: 36
+            reserved: 0
         -
             start_resource: 112
             num_resource: 4
@@ -925,6 +931,12 @@ rm-cfg:
             type: 1949
             host_id: 12
             reserved: 0
+        -
+            start_resource: 224
+            num_resource: 64
+            type: 1949
+            host_id: 36
+            reserved: 0
         -
             start_resource: 0
             num_resource: 4
@@ -997,6 +1009,12 @@ rm-cfg:
             type: 1960
             host_id: 12
             reserved: 0
+        -
+            start_resource: 34
+            num_resource: 8
+            type: 1960
+            host_id: 36
+            reserved: 0
         -
             start_resource: 0
             num_resource: 4
@@ -1159,12 +1177,24 @@ rm-cfg:
             type: 1975
             host_id: 12
             reserved: 0
+        -
+            start_resource: 25
+            num_resource: 4
+            type: 1975
+            host_id: 36
+            reserved: 0
         -
             start_resource: 112
             num_resource: 64
             type: 1976
             host_id: 12
             reserved: 0
+        -
+            start_resource: 112
+            num_resource: 64
+            type: 1976
+            host_id: 36
+            reserved: 0
         -
             start_resource: 0
             num_resource: 1
-- 
