+#include "rproc_trace_status.h"
 
 typedef enum {
 	INIT,
@@ -248,6 +249,12 @@ static int initial_send_pdelay_req_proc(md_pdelay_req_data_t *sm, uint64_t cts64
 	sm->thisSM->pdelayReqSequenceId = (uint16_t)rand();
