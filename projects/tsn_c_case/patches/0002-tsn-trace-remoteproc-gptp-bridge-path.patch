 	if(res<0){
@@ -275,8 +282,21 @@ static md_pdelay_req_state_t initial_send_pdelay_req_condition(md_pdelay_req_dat
 		if(sm->mock_txts64!=0u){
 			sm->t1ts64=sm->mock_txts64;
 			sm->mock_txts64=0;
+			if (sm->portIndex == 2) {
+				RPROC_TRACE_INFO("gptp_pdelay", "mock_txts", 0,
