 		// repeat to send the initial PDelayReq
@@ -633,6 +653,26 @@ static void *waiting_for_pdelay_interval_timer_proc(md_pdelay_req_data_t *sm)
 			sm->ppg->forAllDomain->neighborPropDelay.nsec);
 	}
 
+	if (sm->portIndex == 2) {
+		const int srcDiff = memcmp(RCVD_PDELAY_RESP_PTR->head.sourcePortIdentity.clockIdentity,
+		                           sm->ptasg->thisClock,
+		                           sizeof(ClockIdentity)) != 0;
+
+		RPROC_TRACE_INFO("gptp_ascross", "sample", 0,
+		                 "port=%d compat2011=%d valid=%d srcDiff=%d neighDelay=%"PRIu64" thresh=%"PRIu64" min=%"PRIu64" respSdo=0x%02x fupSdo=0x%02x respDom=%u fupDom=%u",
+		                 sm->portIndex,
+		                 sm->is2011BackwardCompatible,
+		                 sm->thisSM->neighborRateRatioValid,
+		                 srcDiff,
+		                 sm->ppg->forAllDomain->neighborPropDelay.nsec,
+		                 sm->mdeg->forAllDomain->neighborPropDelayThresh.nsec,
+		                 sm->mdeg->forAllDomain->neighborPropDelayMinLimit.nsec,
+		                 (unsigned int)(RCVD_PDELAY_RESP_PTR->head.majorSdoId_messageType & 0xF0u),
+		                 (unsigned int)(RCVD_PDELAY_RESP_FOLLOWUP_PTR->head.majorSdoId_messageType & 0xF0u),
+		                 (unsigned int)RCVD_PDELAY_RESP_PTR->head.domainNumber,
+		                 (unsigned int)RCVD_PDELAY_RESP_FOLLOWUP_PTR->head.domainNumber);
+	}
+
 	sm->mdeg->forAllDomain->isMeasuringDelay = true;
 
 	// In addition to the conditions in 802.1AS-2020 Figure 11-9
@@ -659,6 +699,14 @@ static void *waiting_for_pdelay_interval_timer_proc(md_pdelay_req_data_t *sm)
 		sm->thisSM->detectedFaults = 0;
 		if(sm->mdeg->forAllDomain->asCapableAcrossDomains){return NULL;}
 		sm->mdeg->forAllDomain->asCapableAcrossDomains = true;
+		if (sm->portIndex == 2) {
+			RPROC_TRACE_INFO("gptp_ascross", "set", 0,
+			                 "port=%d neighDelay=%"PRIu64" valid=%d compat2011=%d",
+			                 sm->portIndex,
+			                 sm->ppg->forAllDomain->neighborPropDelay.nsec,
+			                 sm->thisSM->neighborRateRatioValid,
+			                 sm->is2011BackwardCompatible);
+		}
 		UB_LOG(UBL_INFO, "%s:set asCapableAcrossDomains, portIndex=%d\n",
 		       __func__, sm->portIndex);
 		return NULL;
@@ -699,6 +747,15 @@ detectedfault:
 	}
 
 noascapable:
+	if (sm->portIndex == 2) {
+		RPROC_TRACE_INFO("gptp_ascross", "clear", 0,
+		                 "port=%d neighDelay=%"PRIu64" valid=%d compat2011=%d detectedFaults=%u",
+		                 sm->portIndex,
+		                 sm->ppg->forAllDomain->neighborPropDelay.nsec,
+		                 sm->thisSM->neighborRateRatioValid,
+		                 sm->is2011BackwardCompatible,
+		                 sm->thisSM->detectedFaults);
+	}
 	UB_LOG(UBL_INFO, "%s:portIndex=%d, not asCapable\n", __func__, sm->portIndex);
 	sm->mdeg->forAllDomain->asCapableAcrossDomains = false;
 	sm->mdeg->forAllDomain->isMeasuringDelay = false;
@@ -846,6 +903,13 @@ void md_pdelay_req_sm_txts(md_pdelay_req_data_t *sm, event_data_txts_t *edtxts,
 	sm->t1ts64=edtxts->ts64 + sm->ppg->egressLatency.scaledNanoseconds;
 	UB_LOG(UBL_DEBUGV, "%s:ts64=%"PRIu64", egressLatency=%"PRId64", t1ts64=%"PRIu64"\n",
 	       __func__, edtxts->ts64, sm->ppg->egressLatency.scaledNanoseconds, sm->t1ts64);
+	if (sm->portIndex == 2) {
+		RPROC_TRACE_INFO("gptp_pdelay", "txts", 0,
