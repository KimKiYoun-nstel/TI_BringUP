+				                 sm->t1ts64);
+			}
 			return WAITING_FOR_PDELAY_RESP;
 		}
+		if (sm->portIndex == 2) {
+			RPROC_TRACE_INFO("gptp_pdelay", "missing_txts", 0,
+			                 "port=%d seq=%u",
+			                 sm->portIndex,
+			                 (unsigned int)sm->thisSM->pdelayReqSequenceId);
+		}
 		UB_TLOG(UBL_WARN,"%s:missing TxTS, portIndex=%d, seqID=%d\n",
