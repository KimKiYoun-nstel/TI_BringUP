diff --git a/source/networking/tsn/tsn-stack/tsn_combase/tilld/sitara/lldenet.c b/source/networking/tsn/tsn-stack/tsn_combase/tilld/sitara/lldenet.c
index 9df1c523..d06f9ba0 100644
--- a/source/networking/tsn/tsn-stack/tsn_combase/tilld/sitara/lldenet.c
+++ b/source/networking/tsn/tsn-stack/tsn_combase/tilld/sitara/lldenet.c
@@ -62,6 +62,16 @@ extern int32_t EnetApp_applyClassifier(Enet_Handle hEnet, uint32_t coreId, uint8
 static LLDEnetTxDma_t s_lldTxDmaTable[LLDNET_TXDMA_CHANNEL_NUM];
 static LLDEnetRxDma_t s_lldRxDmaTable[LLDNET_RXDMA_CHANNEL_NUM];
 
+typedef struct LLDEnetTxTraceStats_s {
+	uint32_t submitCalls;
+	uint32_t submitPkts;
+	uint32_t noBufHits;
+	uint32_t doneCalls;
+	uint32_t donePkts;
+} LLDEnetTxTraceStats;
+
+static LLDEnetTxTraceStats s_lldTxTraceStats[LLDNET_TXDMA_CHANNEL_NUM];
+
 #define TXDMA_LOCK(hLLDTxDma) \
 	{if(CB_THREAD_IS_MUTEX_INITIALIZED(hLLDTxDma->txMutex))\
 		{CB_THREAD_MUTEX_LOCK(&hLLDTxDma->txMutex);}}
@@ -263,6 +273,7 @@ static int DmaTxOpen(LLDEnet_t *hLLDEnet)
 	EnetApp_GetDmaHandleInArgs txInArgs;
 	EnetApp_GetTxDmaHandleOutArgs txChInfo;
 	LLDEnetTxDma_t *hLLDTxDma = hLLDEnet->hLLDTxDma;
+	LLDEnetTxTraceStats *traceStats = &s_lldTxTraceStats[hLLDTxDma->txChId];
 
 	/* Open the TX channel */
 	txInArgs.cbArg = hLLDTxDma;
@@ -272,6 +283,9 @@ static int DmaTxOpen(LLDEnet_t *hLLDEnet)
 	hLLDTxDma->txChNum = txChInfo.txChNum;
 	hLLDTxDma->hTxCh = txChInfo.hTxCh;
 	EnetAppUtils_assert(hLLDTxDma->hTxCh != NULL);
+	memset(traceStats, 0, sizeof(*traceStats));
+	UB_LOG(UBL_INFO, "%s: txChId=%d txChNum=%d hTxCh=%p\n",
+	       __func__, hLLDTxDma->txChId, hLLDTxDma->txChNum, hLLDTxDma->hTxCh);
 
 	DmaTxQInit(hLLDTxDma);
 
@@ -504,6 +518,7 @@ static uint32_t LLDEnetRetrieveTxDonePkts(LLDEnetTxDma_t *hLLDTxDma)
 	EnetDma_PktQ txFreeQ;
 	int32_t status;
 	uint32_t txFreeQCnt = 0U;
+	LLDEnetTxTraceStats *traceStats = &s_lldTxTraceStats[hLLDTxDma->txChId];
 
 	EnetQueue_initQ(&txFreeQ);
 
@@ -512,9 +527,23 @@ static uint32_t LLDEnetRetrieveTxDonePkts(LLDEnetTxDma_t *hLLDTxDma)
 	txFreeQCnt = EnetQueue_getQCount(&txFreeQ);
 	if (status == ENET_SOK) {
 		EnetAppUtils_validatePacketState(&txFreeQ,
-										 ENET_PKTSTATE_APP_WITH_DRIVER,
-										 ENET_PKTSTATE_APP_WITH_FREEQ);
+						 ENET_PKTSTATE_APP_WITH_DRIVER,
+						 ENET_PKTSTATE_APP_WITH_FREEQ);
 		EnetQueue_append(&hLLDTxDma->txFreePktInfoQ, &txFreeQ);
+		if (txFreeQCnt > 0U) {
+			traceStats->doneCalls++;
+			traceStats->donePkts += txFreeQCnt;
+			if ((traceStats->doneCalls <= 8U) || ((traceStats->doneCalls % 32U) == 0U)) {
+				UB_LOG(UBL_INFO,
+				       "%s: txChId=%d doneCalls=%u donePkts=%u lastDone=%u freeQ=%u\n",
+				       __func__,
+				       hLLDTxDma->txChId,
+				       traceStats->doneCalls,
+				       traceStats->donePkts,
+				       txFreeQCnt,
+				       EnetQueue_getQCount(&hLLDTxDma->txFreePktInfoQ));
+			}
+		}
 	}
 
 	return txFreeQCnt;
@@ -671,6 +700,21 @@ int LLDEnetSendMultiScatter(LLDEnet_t *hLLDEnet, LLDEnetFrameScatter_t *frames,
 
 	/* Don't return in the middle from here, use goto to avoid missing TXDMA_UNLOCK */
 	if (EnetQueue_getQCount(&hLLDTxDma->txFreePktInfoQ) < nFrames) {
+		LLDEnetTxTraceStats *traceStats = &s_lldTxTraceStats[hLLDTxDma->txChId];
+
+		traceStats->noBufHits++;
+		if ((traceStats->noBufHits <= 8U) || ((traceStats->noBufHits % 32U) == 0U)) {
+			UB_LOG(UBL_ERROR,
+			       "%s: txChId=%d no-buf freeQ=%u need=%u submitCalls=%u submitPkts=%u doneCalls=%u donePkts=%u\n",
+			       __func__,
+			       hLLDTxDma->txChId,
+			       EnetQueue_getQCount(&hLLDTxDma->txFreePktInfoQ),
+			       nFrames,
+			       traceStats->submitCalls,
+			       traceStats->submitPkts,
+			       traceStats->doneCalls,
+			       traceStats->donePkts);
+		}
 		res=LLDENET_E_NOBUF;
 		goto exit;
 	}
@@ -720,9 +764,27 @@ int LLDEnetSendMultiScatter(LLDEnet_t *hLLDEnet, LLDEnetFrameScatter_t *frames,
 
 	status = EnetDma_submitTxPktQ(hLLDTxDma->hTxCh, &txSubmitQ);
 	if(status != ENET_SOK) {
+		UB_LOG(UBL_ERROR, "%s: txChId=%d submit failed status=%d\n",
+		       __func__, hLLDTxDma->txChId, status);
 		res=LLDENET_E_DMA;
 		goto exit;
 	}
+	{
+		LLDEnetTxTraceStats *traceStats = &s_lldTxTraceStats[hLLDTxDma->txChId];
+
+		traceStats->submitCalls++;
+		traceStats->submitPkts += nFrames;
+		if ((traceStats->submitCalls <= 8U) || ((traceStats->submitCalls % 32U) == 0U)) {
+			UB_LOG(UBL_INFO,
+			       "%s: txChId=%d submitCalls=%u submitPkts=%u sent=%u freeQ=%u\n",
+			       __func__,
+			       hLLDTxDma->txChId,
+			       traceStats->submitCalls,
+			       traceStats->submitPkts,
+			       nFrames,
+			       EnetQueue_getQCount(&hLLDTxDma->txFreePktInfoQ));
+		}
+	}
 	res=LLDENET_E_OK;
 exit:
 	TXDMA_UNLOCK(hLLDTxDma);
diff --git a/source/networking/tsn/tsn-stack/tsn_gptp/gptpman.c b/source/networking/tsn/tsn-stack/tsn_gptp/gptpman.c
index 86e48581..08152fcc 100644
--- a/source/networking/tsn/tsn-stack/tsn_gptp/gptpman.c
+++ b/source/networking/tsn/tsn-stack/tsn_gptp/gptpman.c
@@ -50,6 +50,7 @@
 #include <signal.h>
 #include <tsn_unibase/unibase.h>
 #include <tsn_combase/combase_link.h>
+#include "rproc_trace_status.h"
 #include "gptpcommon.h"
 #include "gptpman_private.h"
 
@@ -82,6 +83,16 @@ static void set_asCapable(uint8_t gptpInstanceIndex, PerTimeAwareSystemGlobal *t
 	// 		2)The value of domainNumber is zero, and the value of sdoId for peer delay messages received
 	// on this PTP Port is 0x100.
 	bool is2011PdelayMsgCompatible = is_rxPdelayMsgAre2011Compatible(gptpInstanceIndex, tasg, ptd);
+	if (ptd->ppglb->thisPort == 2) {
+		RPROC_TRACE_INFO("gptp_ascap", "eval", 0,
+		                 "domain=%d port=%d across=%d neigh=%d compat2011=%d asCap=%d",
+		                 tasg->domainIndex,
+		                 ptd->ppglb->thisPort,
+		                 ptd->mdeglb->forAllDomain->asCapableAcrossDomains,
+		                 ptd->ppglb->neighborGptpCapable,
+		                 is2011PdelayMsgCompatible,
+		                 ptd->ppglb->asCapable);
+	}
 	if(ptd->mdeglb->forAllDomain->asCapableAcrossDomains &&
 	    (ptd->ppglb->neighborGptpCapable || is2011PdelayMsgCompatible)){
 		if(ptd->ppglb->asCapable){return;}
@@ -118,6 +129,14 @@ static void update_asCapable_for_all(gptpman_data_t *gpmand, int domainIndex,
 		if(!DOMAIN_DATA_EXIST(di)){continue;}
 		set_asCapable(gpmand->gptpInstanceIndex, gpmand->tasds[di].tasglb,
 			      &gpmand->tasds[di].ptds[portIndex]);
+		if (portIndex == 2) {
+			RPROC_TRACE_INFO("gptp_ascap", "update", 0,
+			                 "domain=%d port=%d asCap=%d asCapOrAll=%d",
+			                 di,
+			                 portIndex,
+			                 gpmand->tasds[di].ptds[portIndex].ppglb->asCapable,
+			                 gpmand->tasds[di].tasglb->asCapableOrAll);
+		}
 		gpmand->tasds[di].tasglb->asCapableOrAll |=
 			gpmand->tasds[di].ptds[portIndex].ppglb->asCapable;
 	}
diff --git a/source/networking/tsn/tsn-stack/tsn_gptp/md_pdelay_req_sm.c b/source/networking/tsn/tsn-stack/tsn_gptp/md_pdelay_req_sm.c
