+static void EnetApp_traceFlowSummary(EnetApp_PerCtxt *perCtxt,
+                                     uint32_t flowIdx,
+                                     const EnetApp_DefaultFlowStats *stats)
+{
+    RPROC_TRACE_INFO("switch_dbg", "flow_stats", 0,
+                     "per_idx=%u flow=%u rx=%u tx=%u drop=%u host_mac=%02x:%02x:%02x:%02x:%02x:%02x",
+                     perCtxt->perIdx,
+                     flowIdx,
+                     stats->rxPkts,
+                     stats->txPkts,
+                     stats->dropPkts,
+                     perCtxt->macAddr[0], perCtxt->macAddr[1], perCtxt->macAddr[2],
+                     perCtxt->macAddr[3], perCtxt->macAddr[4], perCtxt->macAddr[5]);
+}
