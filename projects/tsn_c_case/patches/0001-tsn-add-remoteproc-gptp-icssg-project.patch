@@ -0,0 +1,20 @@
+/*
+ * Remoteproc trace helper for the Linux remoteproc-based ICSSG gPTP scaffold.
+ */
+
+#ifndef RPROC_TRACE_STATUS_H_
+#define RPROC_TRACE_STATUS_H_
+
+#include <kernel/dpl/DebugP.h>
+
+#define RPROC_TRACE_INFO(stage, state, code, fmt, ...) \
+    DebugP_log("[RPROC_TRACE] stage=%s state=%s code=%d " fmt "\r\n", \
+               stage, state, code, ##__VA_ARGS__)
+
+#define RPROC_TRACE_OK(stage, fmt, ...) \
+    RPROC_TRACE_INFO(stage, "ok", 0, fmt, ##__VA_ARGS__)
+
+#define RPROC_TRACE_ERR(stage, code, fmt, ...) \
+    RPROC_TRACE_INFO(stage, "error", code, fmt, ##__VA_ARGS__)
+
+#endif /* RPROC_TRACE_STATUS_H_ */
