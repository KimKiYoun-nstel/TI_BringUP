+ *  DATA, OR PROFITS; OR BUSINESS INTERRUPTION) HOWEVER CAUSED AND ON ANY
+ *  THEORY OF LIABILITY, WHETHER IN CONTRACT, STRICT LIABILITY, OR TORT
+ *  (INCLUDING NEGLIGENCE OR OTHERWISE) ARISING IN ANY WAY OUT OF THE USE
+ *  OF THIS SOFTWARE, EVEN IF ADVISED OF THE POSSIBILITY OF SUCH DAMAGE.
+ */
+
+#include <stdlib.h>
+#include <kernel/dpl/DebugP.h>
+#include "ti_drivers_config.h"
+#include "ti_board_config.h"
+#include "ti_drivers_open_close.h"
+#include "ti_board_open_close.h"
+#include "rproc_trace_status.h"
+#include "FreeRTOS.h"
+#include "task.h"
+
+#define MAIN_TASK_PRI  (2)
+
+#define MAIN_TASK_SIZE (16384U/sizeof(configSTACK_DEPTH_TYPE))
+StackType_t gMainTaskStack[MAIN_TASK_SIZE] __attribute__((aligned(32)));
+
+StaticTask_t gMainTaskObj;
+TaskHandle_t gMainTask;
+
+void ipc_rpmsg_echo_main(void *args);
+
+void freertos_main(void *args)
+{
+    int32_t status = SystemP_SUCCESS;
+
+    RPROC_TRACE_OK("boot", "PathB gptp switch entry");
+
+    RPROC_TRACE_OK("boot", "Drivers_open start");
+    Drivers_open();
+    RPROC_TRACE_OK("boot", "Drivers_open done");
+
+    RPROC_TRACE_OK("boot", "Board_driversOpen start");
+    status = Board_driversOpen();
+    if (status != SystemP_SUCCESS)
+    {
+        RPROC_TRACE_ERR("boot", status, "Board_driversOpen failed");
+    }
+    else
+    {
+        RPROC_TRACE_OK("boot", "Board_driversOpen done");
+    }
+    DebugP_assert(status == SystemP_SUCCESS);
+
+    ipc_rpmsg_echo_main(args);
+
+    RPROC_TRACE_OK("boot", "Board_driversClose start");
+    Board_driversClose();
+    RPROC_TRACE_OK("boot", "Board_driversClose done");
+
+    RPROC_TRACE_OK("boot", "Drivers_close start");
+    Drivers_close();
+    RPROC_TRACE_OK("boot", "Drivers_close done");
+
+    vTaskDelete(NULL);
+}
+
+
+int main(void)
+{
+    RPROC_TRACE_INFO("boot", "enter", 0, "main start");
+
+    /* init SOC specific modules */
+    RPROC_TRACE_OK("boot", "System_init call start");
+    System_init();
+    RPROC_TRACE_OK("boot", "System_init call done");
+
+    RPROC_TRACE_OK("boot", "Board_init call start");
+    Board_init();
+    RPROC_TRACE_OK("boot", "Board_init call done");
+
+    RPROC_TRACE_OK("boot", "system and board init complete");
+
+    /* This task is created at highest priority, it should create more tasks and then delete itself */
+    RPROC_TRACE_OK("boot", "main task create start pri=%d stack_words=%u", MAIN_TASK_PRI, (unsigned int)MAIN_TASK_SIZE);
+    gMainTask = xTaskCreateStatic( freertos_main,   /* Pointer to the function that implements the task. */
+                                  "freertos_main", /* Text name for the task.  This is to facilitate debugging only. */
+                                  MAIN_TASK_SIZE,  /* Stack depth in units of StackType_t typically uint32_t on 32b CPUs */
+                                  NULL,            /* We are not using the task parameter. */
+                                  MAIN_TASK_PRI,   /* task priority, 0 is lowest priority, configMAX_PRIORITIES-1 is highest */
+                                  gMainTaskStack,  /* pointer to stack base */
+                                  &gMainTaskObj ); /* pointer to statically allocated task object memory */
+    configASSERT(gMainTask != NULL);
+
+    RPROC_TRACE_OK("boot", "main task created");
+
+    /* Start the scheduler to start the tasks executing. */
+    vTaskStartScheduler();
+
+    RPROC_TRACE_ERR("boot", -1, "scheduler returned unexpectedly");
+
+    /* The following line should never be reached because vTaskStartScheduler()
+    will only return if there was not enough FreeRTOS heap memory available to
+    create the Idle and (if configured) Timer tasks.  Heap management, and
+    techniques for trapping heap exhaustion, are described in the book text. */
+    DebugP_assertNoLog(0);
+
+    return 0;
+}
diff --git a/ccs_projects/gptp_icssg_linux_remoteproc_am64x-evm_r5fss0-0_freertos_ti-arm-clang/makefile.defs b/ccs_projects/gptp_icssg_linux_remoteproc_am64x-evm_r5fss0-0_freertos_ti-arm-clang/makefile.defs
new file mode 100644
index 00000000..9e5f2316
--- /dev/null
+++ b/ccs_projects/gptp_icssg_linux_remoteproc_am64x-evm_r5fss0-0_freertos_ti-arm-clang/makefile.defs
@@ -0,0 +1,11 @@
+GEN_FILES__QUOTED += \
+*.appimage* \
+*.appimage_xip \
+*.rprc* \
+*.rprc_xip \
