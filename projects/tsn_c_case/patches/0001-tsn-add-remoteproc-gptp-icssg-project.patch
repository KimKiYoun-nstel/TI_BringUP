+
+static void EnetApp_traceFlowMac(const char *state,
+                                 uint32_t perIdx,
+                                 uint32_t flowIdx,
+                                 uint32_t macCount,
+                                 const uint8_t *macAddr)
+{
+    RPROC_TRACE_INFO("switch_dbg", state, 0,
+                     "per_idx=%u flow=%u mac_count=%u mac=%02x:%02x:%02x:%02x:%02x:%02x",
+                     perIdx,
+                     flowIdx,
+                     macCount,
+                     macAddr[0], macAddr[1], macAddr[2],
+                     macAddr[3], macAddr[4], macAddr[5]);
+}
+
+static void EnetApp_traceFrameSample(const char *state,
+                                     uint32_t perIdx,
+                                     uint32_t flowIdx,
+                                     uint32_t seq,
+                                     const EthFrame *frame,
+                                     uint32_t frameLen)
+{
+    uint16_t etherType = Enet_ntohs(frame->hdr.etherType);
+
+    if ((etherType == ETHERTYPE_VLAN_TAG) && (frameLen >= sizeof(EthVlanFrameHeader)))
+    {
+        const EthVlanFrame *vlanFrame = (const EthVlanFrame *)frame;
+        uint16_t tci = Enet_ntohs(vlanFrame->hdr.tci);
+        uint16_t innerType = Enet_ntohs(vlanFrame->hdr.etherType);
+
+        RPROC_TRACE_INFO("switch_dbg", state, 0,
+                         "per_idx=%u flow=%u seq=%u len=%u dst=%02x:%02x:%02x:%02x:%02x:%02x src=%02x:%02x:%02x:%02x:%02x:%02x vlan_vid=%u vlan_pcp=%u inner=0x%04x",
+                         perIdx,
+                         flowIdx,
+                         seq,
+                         frameLen,
+                         vlanFrame->hdr.dstMac[0], vlanFrame->hdr.dstMac[1], vlanFrame->hdr.dstMac[2],
+                         vlanFrame->hdr.dstMac[3], vlanFrame->hdr.dstMac[4], vlanFrame->hdr.dstMac[5],
+                         vlanFrame->hdr.srcMac[0], vlanFrame->hdr.srcMac[1], vlanFrame->hdr.srcMac[2],
+                         vlanFrame->hdr.srcMac[3], vlanFrame->hdr.srcMac[4], vlanFrame->hdr.srcMac[5],
+                         (uint32_t)(tci & 0x0FFFU),
+                         (uint32_t)((tci >> 13U) & 0x7U),
+                         innerType);
+    }
+    else
+    {
+        RPROC_TRACE_INFO("switch_dbg", state, 0,
+                         "per_idx=%u flow=%u seq=%u len=%u dst=%02x:%02x:%02x:%02x:%02x:%02x src=%02x:%02x:%02x:%02x:%02x:%02x ether=0x%04x",
+                         perIdx,
+                         flowIdx,
+                         seq,
+                         frameLen,
+                         frame->hdr.dstMac[0], frame->hdr.dstMac[1], frame->hdr.dstMac[2],
+                         frame->hdr.dstMac[3], frame->hdr.dstMac[4], frame->hdr.dstMac[5],
+                         frame->hdr.srcMac[0], frame->hdr.srcMac[1], frame->hdr.srcMac[2],
+                         frame->hdr.srcMac[3], frame->hdr.srcMac[4], frame->hdr.srcMac[5],
+                         etherType);
+    }
+}
