diff --git a/ccs_projects/gptp_icssg_linux_remoteproc_am64x-evm_r5fss0-0_freertos_ti-arm-clang/ti_power_clock_config.remoteproc.c b/ccs_projects/gptp_icssg_linux_remoteproc_am64x-evm_r5fss0-0_freertos_ti-arm-clang/ti_power_clock_config.remoteproc.c
new file mode 100644
index 00000000..f081977b
--- /dev/null
+++ b/ccs_projects/gptp_icssg_linux_remoteproc_am64x-evm_r5fss0-0_freertos_ti-arm-clang/ti_power_clock_config.remoteproc.c
@@ -0,0 +1,221 @@
+/*
+ * Remoteproc-specific override for the generated ti_power_clock_config.c.
+ *
+ * SysConfig regenerates the default file on every build, so this curated copy
+ * is restored immediately after generation to keep the Path B ownership
+ * verification changes stable.
+ */
+
+#include <kernel/dpl/DebugP.h>
+#include <drivers/sciclient.h>
+#include <drivers/soc.h>
+
+#include "rproc_trace_status.h"
+
+#define SOC_MODULES_END              (0xFFFFFFFFu)
+#define ENETAPP_REMOTEPROC_HOSTED    (1U)
+
+typedef struct {
+
+    uint32_t moduleId;
+    uint32_t clkId;
+    uint32_t clkRate;
+    uint32_t clkParentId;
+
+} SOC_ModuleClockFrequency;
+
+uint32_t gSocModules[] = {
+    TISCI_DEV_I2C0,
+    TISCI_DEV_I2C1,
+
+    TISCI_DEV_PRU_ICSSG1,
+
+    SOC_MODULES_END,
+};
+
+SOC_ModuleClockFrequency gSocModulesClockFrequency[] = {
+
+    { TISCI_DEV_PRU_ICSSG1, TISCI_DEV_PRU_ICSSG1_CORE_CLK, 333333333, TISCI_DEV_PRU_ICSSG0_CORE_CLK_PARENT_POSTDIV4_16FF_MAIN_0_HSDIVOUT9_CLK },
+    { TISCI_DEV_PRU_ICSSG1, TISCI_DEV_PRU_ICSSG1_UCLK_CLK, 192000000, SOC_MODULES_END },
+    { TISCI_DEV_PRU_ICSSG1, TISCI_DEV_PRU_ICSSG1_IEP_CLK, 200000000, TISCI_DEV_PRU_ICSSG0_IEP_CLK_PARENT_POSTDIV4_16FF_MAIN_0_HSDIVOUT6_CLK },
+
+    { SOC_MODULES_END, SOC_MODULES_END, SOC_MODULES_END, SOC_MODULES_END },
+};
+
+static uint32_t Module_shouldSkipClockSet(uint32_t moduleId, uint32_t clkId)
+{
+#if ENETAPP_REMOTEPROC_HOSTED
+    (void)clkId;
+
+    if (moduleId == TISCI_DEV_PRU_ICSSG1)
+    {
+        return 1U;
+    }
+#endif
+
+    return 0U;
+}
+
+static void Module_traceClockState(uint32_t moduleId, uint32_t clkId)
+{
+    int32_t status;
+    uint32_t parent = 0U;
+    uint64_t freq = 0U;
+
+    status = Sciclient_pmGetModuleClkParent(moduleId, clkId, &parent, SystemP_WAIT_FOREVER);
+    if (status == SystemP_SUCCESS)
+    {
+        RPROC_TRACE_INFO("boot", "pwr_clk_get_parent", status,
+                         "module=%u clk=%u parent=%u",
+                         moduleId, clkId, parent);
+    }
+    else
+    {
+        RPROC_TRACE_ERR("boot", status,
+                        "pwr_clk_get_parent_failed module=%u clk=%u",
+                        moduleId, clkId);
+    }
+
+    status = SOC_moduleGetClockFrequency(moduleId, clkId, &freq);
+    if (status == SystemP_SUCCESS)
+    {
+        RPROC_TRACE_INFO("boot", "pwr_clk_get_freq", status,
+                         "module=%u clk=%u freq=%u",
+                         moduleId, clkId, (uint32_t)freq);
+    }
+    else
+    {
+        RPROC_TRACE_ERR("boot", status,
+                        "pwr_clk_get_freq_failed module=%u clk=%u",
+                        moduleId, clkId);
+    }
+}
+
+void Module_clockEnable(void)
+{
+    int32_t status;
+    uint32_t i = 0;
+
+    while (gSocModules[i] != SOC_MODULES_END)
+    {
+        RPROC_TRACE_INFO("boot", "pwr_mod_enable_start", 0,
+                         "module=%u idx=%u", gSocModules[i], i);
+        status = SOC_moduleClockEnable(gSocModules[i], 1);
+        if (status != SystemP_SUCCESS)
+        {
+            RPROC_TRACE_ERR("boot", status,
+                            "pwr_mod_enable_failed module=%u idx=%u",
+                            gSocModules[i], i);
+        }
+        else
+        {
+            RPROC_TRACE_INFO("boot", "pwr_mod_enable_done", 0,
+                             "module=%u idx=%u", gSocModules[i], i);
+        }
+        DebugP_assertNoLog(status == SystemP_SUCCESS);
+        i++;
+    }
+}
+
+void Module_clockDisable(void)
+{
+    int32_t status;
+    uint32_t i = 0;
+
+    while (gSocModules[i] != SOC_MODULES_END)
+    {
+        status = SOC_moduleClockEnable(gSocModules[i], 0);
+        DebugP_assertNoLog(status == SystemP_SUCCESS);
+        i++;
+    }
+}
+
+void Module_clockSetFrequency(void)
+{
+    int32_t status;
+    uint32_t i = 0;
+
+    while (gSocModulesClockFrequency[i].moduleId != SOC_MODULES_END)
+    {
+        RPROC_TRACE_INFO("boot", "pwr_clk_set_start", 0,
+                         "module=%u clk=%u rate=%u parent=%u idx=%u",
+                         gSocModulesClockFrequency[i].moduleId,
+                         gSocModulesClockFrequency[i].clkId,
+                         gSocModulesClockFrequency[i].clkRate,
+                         gSocModulesClockFrequency[i].clkParentId,
+                         i);
+
+        if (Module_shouldSkipClockSet(gSocModulesClockFrequency[i].moduleId,
+                                      gSocModulesClockFrequency[i].clkId) != 0U)
+        {
+            Module_traceClockState(gSocModulesClockFrequency[i].moduleId,
+                                   gSocModulesClockFrequency[i].clkId);
+
+            RPROC_TRACE_INFO("boot", "pwr_clk_set_skip", 0,
+                             "module=%u clk=%u reason=remoteproc_hosted_policy idx=%u",
+                             gSocModulesClockFrequency[i].moduleId,
+                             gSocModulesClockFrequency[i].clkId,
+                             i);
+            i++;
+            continue;
+        }
+
+        if (gSocModulesClockFrequency[i].clkParentId != SOC_MODULES_END)
+        {
+            /* Set module clock to specified frequency and with a specific parent */
+            status = SOC_moduleSetClockFrequencyWithParent(
+                        gSocModulesClockFrequency[i].moduleId,
+                        gSocModulesClockFrequency[i].clkId,
+                        gSocModulesClockFrequency[i].clkParentId,
+                        gSocModulesClockFrequency[i].clkRate
+                        );
+        }
+        else
+        {
+            /* Set module clock to specified frequency */
+            status = SOC_moduleSetClockFrequency(
+                        gSocModulesClockFrequency[i].moduleId,
+                        gSocModulesClockFrequency[i].clkId,
+                        gSocModulesClockFrequency[i].clkRate
+                        );
+        }
+
+        if (status != SystemP_SUCCESS)
+        {
+            RPROC_TRACE_ERR("boot", status,
+                            "pwr_clk_set_failed module=%u clk=%u rate=%u parent=%u idx=%u",
+                            gSocModulesClockFrequency[i].moduleId,
+                            gSocModulesClockFrequency[i].clkId,
+                            gSocModulesClockFrequency[i].clkRate,
+                            gSocModulesClockFrequency[i].clkParentId,
+                            i);
+        }
+        else
+        {
+            RPROC_TRACE_INFO("boot", "pwr_clk_set_done", 0,
+                             "module=%u clk=%u rate=%u parent=%u idx=%u",
+                             gSocModulesClockFrequency[i].moduleId,
+                             gSocModulesClockFrequency[i].clkId,
+                             gSocModulesClockFrequency[i].clkRate,
+                             gSocModulesClockFrequency[i].clkParentId,
+                             i);
+        }
+
+        DebugP_assertNoLog(status == SystemP_SUCCESS);
+        i++;
+    }
+}
+
+void PowerClock_init(void)
+{
+    RPROC_TRACE_OK("boot", "PowerClock_init enter");
+    Module_clockEnable();
+    RPROC_TRACE_OK("boot", "PowerClock_init module enable done");
+    Module_clockSetFrequency();
+    RPROC_TRACE_OK("boot", "PowerClock_init clock set done");
+}
+
+void PowerClock_deinit(void)
+{
+    Module_clockDisable();
+}
