{
  "$schema": "https://opencode.ai/config.json",
  "mcp": {
    "uart": {
      "type": "local",
      "command": [
        "/usr/bin/python3",
        "/home/nstel/ti/TI_Bringup/tools/uart/uart-mcp-server.py",
        "--socket",
        "/home/nstel/ti/TI_Bringup/logs/uartd.sock"
      ],
      "enabled": true,
      "environment": {
        "PYTHONUNBUFFERED": "1",
        "UARTD_SOCKET": "/home/nstel/ti/TI_Bringup/logs/uartd.sock",
        "UART_MCP_DEFAULT_NEWLINE": "crlf",
        "UART_MCP_DEFAULT_TIMEOUT": "10"
      }
    }
  }
}
