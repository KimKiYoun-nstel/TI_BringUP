{
  "$schema": "https://opencode.ai/config.json",
  "mcp": {
    "uart": {
      "type": "local",
      "command": [
        "python3",
        "./tools/uart/uart-mcp-server.py",
        "--socket",
        "./logs/uartd.sock"
      ],
      "enabled": true,
      "environment": {
        "UARTD_SOCKET": "./logs/uartd.sock",
        "UART_MCP_DEFAULT_NEWLINE": "crlf",
        "UART_MCP_DEFAULT_TIMEOUT": "10"
      }
    }
  }
}
